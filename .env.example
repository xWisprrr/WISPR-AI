# WISPR AI OS — environment variables
# Copy this file to .env and fill in your values.

# ── LLM API Keys (at least one is required) ──────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Model routing (optional overrides) ───────────────────────────────────────
REASONING_MODEL=gpt-4o
CODING_MODEL=gpt-4o
SEARCH_MODEL=gpt-4o-mini
GENERAL_MODEL=gpt-4o-mini
FALLBACK_MODEL=gpt-4o-mini

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── SearXNG (optional: use your own instance for privacy) ────────────────────
SEARXNG_URL=https://searx.be

# ── Memory ───────────────────────────────────────────────────────────────────
MEMORY_DIR=memory/store
LONG_TERM_DB_PATH=memory/store/long_term.json
TASK_MEMORY_DB_PATH=memory/store/tasks.json
